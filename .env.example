PORT=4000
NODE_ENV=development

# MongoDB (required). URL-encode special characters in the password.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/wineroad?retryWrites=true&w=majority

# Admin JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Admin login (email must match login form)
ADMIN_EMAIL=admin@wineroad.am

# Prefer bcrypt hash in production (e.g. bcrypt.hashSync("your-password", 10))
# ADMIN_PASSWORD_HASH=$2a$10$...
# For local dev only, you may omit ADMIN_PASSWORD_HASH and set:
ADMIN_PASSWORD=change-me

# Comma-separated browser origins (subdomain + main site). Empty = allow all (dev).
CORS_ORIGINS=http://localhost:3000,https://wineroad.am,https://admin.wineroad.am

# Optional public origin used when generating uploaded image URLs.
# PUBLIC_API_BASE_URL=https://api.wineroad.am
